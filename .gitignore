# =============================================================================
# .gitignore — Real-Time Predictive Ball Tracking System
# Python (pc_app) | OpenMV MicroPython (firmware) | LaTeX (MATH-470 paper)
# macOS | Arduino IDE | VS Code | PyCharm
# =============================================================================


# =============================================================================
# PYTHON
# =============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/
.env

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/
nosetests.xml
test-results/

# mypy / type checking
.mypy_cache/
.dmypy.json
dmypy.json

# Pyright
pyrightconfig.json

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb

# pyenv
.python-version


# =============================================================================
# PROJECT-SPECIFIC
# =============================================================================

# Recorded serial sessions — large binary/csv data files
# Intentional demo assets should be committed explicitly; raw captures should not
tools/sessions/
*.session.csv

# Calibration output dumps (auto-generated by calibrate_color.py)
tools/calibration_output/
*.cal.json

# Log files from test runs or serial output
logs/
*.log

# Any local config overrides (serial port, display size, etc.)
# Commit config.py with defaults only; local overrides go here
pc_app/config_local.py

# Benchmark / profiling output
*.prof
*.pstats


# =============================================================================
# OpenMV / MICROPYTHON / ARDUINO
# =============================================================================

# OpenMV IDE workspace files
*.openmv_ide/

# OpenMV compiled bytecode
*.mpy

# Arduino IDE build output
build/
*.elf
*.bin
*.hex
*.map

# Arduino IDE library cache
libraries/

# Arduino IDE preferences (local to machine)
preferences.txt

# CMake (used by some Arduino toolchains)
CMakeFiles/
CMakeCache.txt
cmake_install.cmake


# =============================================================================
# LATEX
# =============================================================================

# Compiled output
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.lof
*.log
*.lot
*.out
*.pdf
*.run.xml
*.synctex.gz
*.toc
*.xdv

# Keep intentionally committed PDFs (e.g. original proposal scan)
# Override with: git add -f MATH_470_Project\ \(1\).pdf
!MATH_470_Project*.pdf

# latexmk
latexmk.log

# BibTeX / Biber
*.bib.bak


# =============================================================================
# macOS
# =============================================================================

.DS_Store
.AppleDouble
.LSOverride

# Icon files
Icon?

# Thumbnails
._*

# Spotlight index files
.Spotlight-V100
.Trashes

# fseventsd
.fseventsd

# Volumes
/Volumes/


# =============================================================================
# EDITORS
# =============================================================================

# VS Code
.vscode/
*.code-workspace

# PyCharm / JetBrains
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
\#*\#
.\#*
*.elc

# TextMate
*.tmproj
*.tmproject
tmtags


# =============================================================================
# SECRETS & CREDENTIALS
# =============================================================================

# Never commit secrets — even for a hardware project
.env
.env.*
secrets.py
secrets.json
*.pem
*.key
*.p12
*.pfx
